{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.srivastsh/muni-mcp",
  "title": "SF Muni Real-Time Transit",
  "description": "Real-time SF Muni departures, routes, alerts, vehicle positions, and schedules.",
  "version": "1.0.0",
  "remotes": [
    {
      "url": "https://muni-mcp.srivastsh.workers.dev/mcp",
      "headers": [
        {
          "name": "x-api-key-511",
          "value": "{$apiKey}"
        }
      ],
      "type": "streamable-http"
    }
  ],
  "environmentVariables": [
    {
      "name": "apiKey",
      "description": "Your 511.org API key. Get a free one at https://511.org/open-data/token",
      "required": true
    }
  ],
  "repository": {
    "url": "https://github.com/srivastsh/bay-area-transit-mcp",
    "source": "github"
  },
  "tools": [
    {
      "name": "transit_operators",
      "description": "List all 511 transit operators"
    },
    {
      "name": "muni_routes",
      "description": "List all SF Muni routes"
    },
    {
      "name": "muni_departures",
      "description": "Real-time departures from a Muni stop"
    },
    {
      "name": "muni_line",
      "description": "Line details with stops"
    },
    {
      "name": "muni_alerts",
      "description": "Current Muni service alerts"
    },
    {
      "name": "muni_vehicles",
      "description": "Real-time vehicle GPS positions"
    },
    {
      "name": "muni_schedule",
      "description": "Timetable for a Muni line"
    }
  ]
}